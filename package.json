{
  "name": "pi-cat",
  "version": "0.2.0",
  "description": "Cat-themed pi package with a phosphor-green palette, customizable header text, and compact telemetry.",
  "license": "MIT",
  "type": "module",
  "keywords": [
    "pi-package",
    "pi",
    "cat",
    "theme",
    "terminal",
    "persona"
  ],
  "files": [
    "extensions/**/*",
    "themes/**/*",
    "README.md",
    "LICENSE",
    "package.json",
    "tsconfig.json"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "pack:check": "npm pack --dry-run"
  },
  "peerDependencies": {
    "@mariozechner/pi-coding-agent": "*",
    "@mariozechner/pi-tui": "*"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "typescript": "^5.9.3"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/lulucatdev/pi-cat.git"
  },
  "pi": {
    "extensions": [
      "./extensions/cat/index.ts"
    ],
    "themes": [
      "./themes"
    ]
  }
}
